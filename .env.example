# app
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# gcp
K_SERVICE=default-service
K_REVISION=default-revision
GOOGLE_CLOUD_PROJECT=local-project
GOOGLE_STORE_BUCKET=local-bucket

# firebase
FIRESTORE_DATABASE_ID=(default)

# blockchain
ALCHEMY_API_KEY=dummy
NETWORK_TYPE=ethereum
NETWORK_ENVIRONMENT=sepolia

# predicate
PREDICATE_API_URL=http://localhost:3001
PREDICATE_API_KEY=dummy

# contract
LIQUIDITY_CONTRACT_ADDRESS=0x
LIQUIDITY_CONTRACT_DEPLOYED_BLOCK=0
WITHDRAWAL_CONTRACT_ADDRESS=0x
L1_SCROLL_MESSENGER_CONTRACT_ADDRESS=0x
MOCK_L1_SCROLL_MESSENGER_CONTRACT_ADDRESS=0x
MOCK_L1_SCROLL_MESSENGER_CONTRACT_DEPLOYED_BLOCK=0
MOCK_L2_SCROLL_MESSENGER_CONTRACT_ADDRESS=0x
MOCK_L2_SCROLL_MESSENGER_CONTRACT_DEPLOYED_BLOCK=0

# private key
INTMAX2_OWNER_MNEMONIC=""
MOCK_MESSENGER_PRIVATE_KEY="0x"

# scroll
SCROLL_GAS_MULTIPLIER=2

# mining
CLAIM_CONTRACT_ADDRESS=0x
MINTER_CONTRACT_ADDRESS=0x
STAKING_RELAYER_ENABLED=false